PORT=8787
CODEX_CONFIG_PATH=~/.codex/config.toml

# Optional. If set, the proxy also loads .env.<ACTIVE_PROVIDER>.
ACTIVE_PROVIDER=openrouter

# Fallback values when ACTIVE_PROVIDER is empty or .env.<provider> is missing.
# BASE_URL=https://your-relay.example.com
# API_KEY=sk-xxx

# Optional. Set to "chat_completions" when the upstream only supports the
# OpenAI Chat Completions API (/v1/chat/completions), not the Responses API
# (/v1/responses). The proxy will translate between the two formats, including
# rewriting the request path, converting request/response bodies, and
# synthesizing response.completed SSE events.
# API_FORMAT=chat_completions
