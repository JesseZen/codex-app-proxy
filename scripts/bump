#!/usr/bin/env bash
# bump — local version management for codex-app-proxy
#
# Usage:
#   ./scripts/bump                    # auto-increment prerelease number
#   ./scripts/bump alpha              # set prerelease to alpha, reset counter
#   ./scripts/bump beta               # set prerelease to beta, reset counter
#   ./scripts/bump rc                 # set prerelease to rc, reset counter
#   ./scripts/bump release            # drop prerelease, produce clean version
#   ./scripts/bump set 2.1.0          # manually set base version (x.y.z)
#
# Version scheme (SemVer + prerelease):
#   alpha:  2.0.0-alpha.1 → 2.0.0-alpha.2 → ...
#   beta:   2.0.0-beta.1  → 2.0.0-beta.2  → ...
#   rc:     2.0.0-rc.1    → 2.0.0-rc.2    → ...
#   release: 2.0.0 → 2.0.1 → ...

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/version-lib.sh"

# ── Validate x.y.z format ───────────────────────────────────────────
validate_xyz() {
  if [[ ! "$1" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "Error: invalid version format '$1', expected x.y.z" >&2
    exit 1
  fi
}

# ── Main logic ──────────────────────────────────────────────────────
main() {
  local cmd="${1:-auto}"
  version_read

  local new_base="$BASE_VERSION"
  local new_pre="$PRERELEASE"
  local new_num="$PRE_NUM"

  case "$cmd" in
    alpha|beta|rc)
      if [[ "$cmd" == "$PRERELEASE" ]]; then
        new_num=$((PRE_NUM + 1))
      else
        new_pre="$cmd"
        new_num=1
      fi
      ;;
    release)
      new_pre="release"
      new_num=0
      ;;
    set)
      if [[ -z "${2:-}" ]]; then
        echo "Usage: ./scripts/bump set <x.y.z>" >&2
        exit 1
      fi
      validate_xyz "$2"
      new_base="$2"
      ;;
    auto)
      if [[ "$PRERELEASE" == "release" || -z "$PRERELEASE" ]]; then
        local x y z
        IFS='.' read -r x y z <<< "$BASE_VERSION"
        z=$((z + 1))
        new_base="$x.$y.$z"
        new_pre="release"
        new_num=0
      else
        new_num=$((PRE_NUM + 1))
      fi
      ;;
    *)
      echo "Usage: ./scripts/bump [alpha|beta|rc|release|set|auto]" >&2
      echo "" >&2
      echo "Commands:" >&2
      echo "  (no args)  auto-increment (prerelease# or patch)" >&2
      echo "  alpha      switch to alpha channel, reset counter" >&2
      echo "  beta       switch to beta channel, reset counter" >&2
      echo "  rc         switch to rc channel, reset counter" >&2
      echo "  release    drop prerelease, produce clean version" >&2
      echo "  set x.y.z  set base version manually" >&2
      exit 1
      ;;
  esac

  local new_ver
  new_ver=$(version_full "$new_base" "$new_pre" "$new_num")

  echo "bump: $(version_full "$BASE_VERSION" "$PRERELEASE" "$PRE_NUM") → $new_ver"

  # Update state file + source files
  version_write "$new_base" "$new_pre" "$new_num"
  version_update_all "$new_ver"

  # Git commit + tag
  local tag="v$new_ver"
  version_stage

  if git diff --cached --quiet; then
    echo "  no files changed, skipping commit"
  else
    git commit -m "[v$new_ver] chore: bump version to $new_ver"
    if git tag -l "$tag" | grep -q .; then
      echo "  warning: tag $tag already exists, skipping tag" >&2
    else
      git tag "$tag"
      echo "  committed and tagged $tag"
    fi
  fi

  echo ""
  echo "✓ version is now $new_ver"
}

main "$@"
